#!/bin/bash

# Exit immediately if a command exits with a non-zero status.
set -e

# Move to the project root (one level up from the script)
cd "$(dirname "$0")/.."

echo "🚀 Starting Wedding Planner Setup..."

# 1. Create Virtual Environment
if [ ! -d ".venv" ]; then
    echo "📦 Creating virtual environment (.venv)..."
    python3 -m venv .venv
else
    echo "✅ Virtual environment already exists."
fi

# 2. Activate Virtual Environment and Install Dependencies
echo "📥 Installing dependencies..."
source .venv/bin/activate
pip install --upgrade pip
pip install -r requirements.txt

# 3. Handle .env file
if [ ! -f ".env" ]; then
    echo "📝 Creating .env from .env.example..."
    cp .env.example .env
    echo "⚠️  Action Required: Update your .env file with your local database credentials!"
else
    echo "✅ .env file already exists."
fi

# 4. Database Setup
echo "🗄️  Setting up Database..."
# Attempt to create database if it doesn't exist (silently ignore if it does)
createdb weddingplanner 2>/dev/null || echo "✅ Database 'weddingplanner' already exists or postgres not running."

# 5. Run Migrations
echo "🏃 Running migrations..."
python manage.py migrate
